{
  "entity": {
    "fan": {
      "vent": {
        "state_attributes": {
          "preset_mode": {
            "default": "mdi:fan",
            "state": {
              "off": "mdi:fan-off",
              "low": "mdi:fan-speed-1",
              "medium": "mdi:fan-speed-2",
              "high": "mdi:fan-speed-3",
              "manual": "mdi:tune-variant"
            }
          }
        }
      }
    }
  },
  "services": {
    "filter_timer_reset": {
      "service": "mdi:air-filter"
    },
    "reset_alarms": {
      "service": "mdi:fan-alert"
    }
  }
}
